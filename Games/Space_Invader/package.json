{
  "scripts": {
    "start": "parcel ./src/index.html",
    "build": "rm -rf build && parcel build -d build --public-url ./ --no-source-maps ./src/index.html",
    "zip": "rm -f bundle.zip && cd build && bestzip ../bundle.zip *",
    "bundle": "yarn build && yarn zip",
    "lint": "eslint src/ts/**/*.ts",
    "lint:fix": "eslint src/ts/**/*.ts --fix",
    "test": "echo \"✅ Tests unitaires - À implémenter\" && exit 0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "bestzip": "^2.2.0",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "parcel-bundler": "^1.12.5",
    "sass": "^1.39.0",
    "typescript": "^4.4.2"
  }
}